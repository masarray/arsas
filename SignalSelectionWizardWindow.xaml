<Window x:Class="ArIED61850Tester.SignalSelectionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Height="730" Width="1220" MinHeight="600" MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}"
        FontFamily="Aptos, Segoe UI Variable Text, Segoe UI, Calibri"
        Icon="Assets/app-icon.ico"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="SignalGridFilterTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#1D2939"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D7DEE9"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding ToolTip}"
                                           Margin="10,0,7,0"
                                           Foreground="#98A2B3"
                                           FontSize="12.5"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="0,2,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SignalGridHeaderCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SignalGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="74"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#F3F6FA"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderBrush" Value="#DCE3EC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="SignalGridSortIndicator" TargetType="ContentControl">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Opacity" Value="0.48"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Viewbox Width="14" Height="14">
                            <Path Data="M7,3 L7,13 M7,3 L4.5,5.5 M7,3 L9.5,5.5 M17,13 L17,3 M17,13 L14.5,10.5 M17,13 L19.5,10.5"
                                  Stroke="#667085" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SortDirection, RelativeSource={RelativeSource AncestorType={x:Type DataGridColumnHeader}}}" Value="Ascending">
                    <Setter Property="Opacity" Value="0.95"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="M12,18 L12,5 M12,5 L7,10 M12,5 L17,10"
                                          Stroke="#2563EB" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Viewbox>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SortDirection, RelativeSource={RelativeSource AncestorType={x:Type DataGridColumnHeader}}}" Value="Descending">
                    <Setter Property="Opacity" Value="0.95"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="M12,6 L12,19 M12,19 L7,14 M12,19 L17,14"
                                          Stroke="#2563EB" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Viewbox>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SignalSelectionCheckBox" TargetType="CheckBox">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="QuickFilterChip" TargetType="ToggleButton">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="11,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="11.8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475467"/>
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="BorderBrush" Value="#E1E7F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF3FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#C9D7F5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E8F0FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9CB8FF"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Compact discovery/search toolbar. The IED identity lives in the native window title. -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="11"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#F8FAFC" BorderBrush="#D8E0EA" BorderThickness="1" CornerRadius="8" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Ellipse Width="13" Height="13" Canvas.Left="3" Canvas.Top="3" Stroke="#667085" StrokeThickness="2"/>
                                <Path Data="M14,14 L21,21" Stroke="#667085" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBox x:Name="GlobalSearchTextBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0,6"
                                 FontSize="12.2"
                                 TextChanged="GlobalFilter_TextChanged"
                                 KeyDown="GlobalSearchTextBox_KeyDown"
                                 ToolTip="Search IEC Telegram, signal, LN, FC, type, category, or acquisition"/>
                        <TextBlock Grid.Column="1"
                                   Text="Search all fields…"
                                   Foreground="#98A2B3"
                                   FontSize="12.2"
                                   Margin="1,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=GlobalSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="2"
                                Content="×"
                                Style="{StaticResource MiniChipButton}"
                                Padding="8,2"
                                Margin="3"
                                Click="ClearGlobalFilter_Click"
                                ToolTip="Clear global search"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="11,0,8,0" VerticalAlignment="Center">
                    <ToggleButton x:Name="QuickAllButton" Content="All" Tag="All" IsChecked="True"
                                  Style="{StaticResource QuickFilterChip}" Click="QuickFilter_Click"/>
                    <ToggleButton x:Name="QuickLiveButton" Content="Live" Tag="Live"
                                  Style="{StaticResource QuickFilterChip}" Click="QuickFilter_Click"/>
                    <ToggleButton x:Name="QuickControlButton" Content="Control" Tag="Control"
                                  Style="{StaticResource QuickFilterChip}" Click="QuickFilter_Click"/>
                    <ToggleButton x:Name="QuickSelectedButton" Content="Selected" Tag="Selected"
                                  Style="{StaticResource QuickFilterChip}" Click="QuickFilter_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="8,0,10,0">
                    <TextBlock Text="{Binding VisibleCountText}"
                               FontSize="11.8"
                               Foreground="#667085"
                               VerticalAlignment="Center"/>
                    <Border Background="#F3F0FF"
                            BorderBrush="#DDD6FE"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,4"
                            Margin="9,0,0,0"
                            Visibility="{Binding FilterStatusVisibility}">
                        <TextBlock Text="{Binding ActiveFiltersText}"
                                   Foreground="#6941C6"
                                   FontSize="11.3"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Clear filters"
                        Style="{StaticResource SoftButton}"
                        Click="ClearFilters_Click"
                        Padding="12,7"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="11"
                ClipToBounds="True">
            <DataGrid x:Name="SignalsGrid"
                      ItemsSource="{Binding SignalsView}"
                      IsReadOnly="False"
                      FrozenColumnCount="2"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="True"
                      HeadersVisibility="Column"
                      ColumnHeaderHeight="74"
                      ColumnHeaderStyle="{StaticResource SignalGridColumnHeader}"
                      Style="{StaticResource ModernDataGrid}"
                      FontSize="12.5"
                      RowHeight="34"
                      BorderThickness="0"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      PreviewMouseLeftButtonUp="SignalsGrid_PreviewMouseLeftButtonUp"
                      PreviewKeyDown="SignalsGrid_PreviewKeyDown"
                      Sorting="SignalsGrid_Sorting">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsControlSignal}" Value="True">
                                <Setter Property="Background" Value="#FBFAFF"/>
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="58" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA">
                                    <TextBlock Text="Use"
                                               Style="{StaticResource SignalGridHeaderCaption}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#D7DEE9" BorderThickness="0,1,0,0">
                                    <CheckBox Tag="VisibleSelection"
                                              IsThreeState="True"
                                              IsChecked="{Binding DataContext.VisibleSelectionState, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Mode=OneWay}"
                                              Style="{StaticResource SignalSelectionCheckBox}"
                                              ToolTip="Select visible rows (Ctrl+A); deselect visible rows (Ctrl+Shift+A)"
                                              Click="VisibleSelectionCheckBox_Click"/>
                                </Border>
                            </Grid>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource SignalSelectionCheckBox}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Binding="{Binding DisplayReference}"
                                        SortMemberPath="DisplayReference"
                                        CanUserSort="True"
                                        Width="350"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand"
                                        ToolTip="Click to sort IEC Telegram">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="IEC Telegram" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="Telegram" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Name}"
                                        SortMemberPath="Name"
                                        CanUserSort="True"
                                        Width="220"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Signal">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="Signal" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="Signal" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding LogicalNode}"
                                        SortMemberPath="LogicalNode"
                                        CanUserSort="True"
                                        Width="140"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Logical Node">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="Logical Node" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="LogicalNode" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding FunctionalConstraint}"
                                        SortMemberPath="FunctionalConstraint"
                                        CanUserSort="True"
                                        Width="82"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Functional Constraint">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="FC" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="FC" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding DataType}"
                                        SortMemberPath="DataType"
                                        CanUserSort="True"
                                        Width="130"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Type">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="Type" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="Type" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Category}"
                                        SortMemberPath="Category"
                                        CanUserSort="True"
                                        Width="125"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Category">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="Category" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="Category" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding ReportPlan}"
                                        SortMemberPath="ReportPlan"
                                        CanUserSort="True"
                                        Width="205"
                                        IsReadOnly="True">
                        <DataGridTextColumn.Header>
                            <Grid Height="74">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="10,0" Background="#F3F6FA" Cursor="Hand" ToolTip="Click to sort Acquisition">
                                    <DockPanel LastChildFill="True">
                                        <ContentControl DockPanel.Dock="Right" Style="{StaticResource SignalGridSortIndicator}" Margin="8,0,0,0"/>
                                        <TextBlock Text="Acquisition" Style="{StaticResource SignalGridHeaderCaption}"/>
                                    </DockPanel>
                                </Border>
                                <TextBox Grid.Row="1" Tag="Acquisition" ToolTip="Filter…"
                                         Style="{StaticResource SignalGridFilterTextBox}"
                                         TextChanged="ColumnFilter_TextChanged"
                                         KeyDown="FilterTextBox_KeyDown"/>
                            </Grid>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="2,10,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectionCountText}"
                           FontSize="12.2"
                           FontWeight="SemiBold"
                           Foreground="#344054"
                           VerticalAlignment="Center"/>
                <Border Width="1" Height="16" Background="#D0D5DD" Margin="11,0"/>
                <TextBlock Text="{Binding VisibleCountText}"
                           FontSize="12"
                           Foreground="#667085"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel"
                        Style="{StaticResource SoftButton}"
                        Click="Cancel_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Apply &amp; Start Live"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click"
                        MinWidth="145"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
