+    [Fact]
+    public void DecodeHeader_ExtractsRoutingIdentityBeforeDataSetMemberMapping()
+    {
+        var decoded = new MmsInformationReport
+        {
+            IsSuccess = true,
+            Items =
+            [
+                new MmsInformationReportItem { Index = 0, Value = MmsDataValue.VisibleString("IEDLD0/LLN0$RP$URCBA02") },
+                new MmsInformationReportItem { Index = 1, Value = MmsDataValue.BitString(6, [0x7B, 0x80]) },
+                new MmsInformationReportItem { Index = 2, Value = MmsDataValue.Unsigned(19) },
+                new MmsInformationReportItem { Index = 3, Value = MmsDataValue.BinaryTime(Convert.FromHexString("04B1EE6A3C8F")) },
+                new MmsInformationReportItem { Index = 4, Value = MmsDataValue.VisibleString("IEDLD0/LLN0$DS_B") },
+                new MmsInformationReportItem { Index = 5, Value = MmsDataValue.Boolean(false) },
+                new MmsInformationReportItem { Index = 6, Value = MmsDataValue.OctetString(Convert.FromHexString("01020304")) },
+                new MmsInformationReportItem { Index = 7, Value = MmsDataValue.Unsigned(7) }
+            ]
+        };
+
+        var header = MmsReportFrameMapper.DecodeHeader(decoded);
+
+        Assert.Equal("IEDLD0/LLN0$RP$URCBA02", header.ReportId);
+        Assert.Equal("IEDLD0/LLN0$DS_B", header.DataSetReference);
+        Assert.Equal((ulong)19, header.SequenceNumber);
+        Assert.Equal((ulong)7, header.ConfRev);
+        Assert.False(header.BufferOverflow);
+        Assert.Equal("01020304", header.EntryIdHex);
+    }
+
 }
