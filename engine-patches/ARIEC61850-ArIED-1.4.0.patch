+using AR.Iec61850.Binding;
+
+namespace AR.Iec61850.Tests.Binding;
+
+public sealed class Iec61850IdentityResolverTests
+{
+    [Fact]
+    public void ResolveFromDomains_PreservesProductDigitsBeforeLogicalDeviceRole()
+    {
+        var identity = Iec61850IdentityResolver.ResolveFromDomains(
+        [
+            "OLSF501ADD",
+            "OLSF501Application",
+            "OLSF501CB1",
+            "OLSF501Ln1_5051OC3phA1",
+            "OLSF501OperationalValues"
+        ],
+        "192.168.1.5",
+        fallbackName: "OLSF");
+
+        Assert.Equal("OLSF501", identity.IedName);
+        Assert.Equal("ADD", identity.LogicalDeviceAliases["OLSF501ADD"]);
+        Assert.Equal("CB1", identity.LogicalDeviceAliases["OLSF501CB1"]);
+        Assert.Equal("Ln1_5051OC3phA1", identity.LogicalDeviceAliases["OLSF501Ln1_5051OC3phA1"]);
+        Assert.Equal("High", identity.Confidence);
+    }
+
+    [Fact]
+    public void ResolveFromDomains_SplitsSingleDomainOrdinalAndRole()
+    {
+        var identity = Iec61850IdentityResolver.ResolveFromDomains(
+            ["OCR7SR12CTRL"],
+            "10.10.10.7");
+
+        Assert.Equal("OCR7SR", identity.IedName);
+        Assert.Equal("12CTRL", identity.LogicalDeviceAliases["OCR7SR12CTRL"]);
+        Assert.Equal("Medium", identity.Confidence);
+    }
+
+    [Fact]
+    public void ResolveFromDomains_DoesNotSplitRoleTextInsideConfiguredIedName()
+    {
+        var identity = Iec61850IdentityResolver.ResolveFromDomains(
+            ["MYCTRLDEVICE"],
+            "10.10.10.8",
+            fallbackName: "MYCTRLDEVICE");
+
+        Assert.Equal("MYCTRLDEVICE", identity.IedName);
+        Assert.Equal("MYCTRLDEVICE", identity.LogicalDeviceAliases["MYCTRLDEVICE"]);
+    }
+}
