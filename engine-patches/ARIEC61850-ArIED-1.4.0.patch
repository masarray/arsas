+    private static string StripLogicalDeviceOrdinal(string candidate)
+    {
+        var end = candidate.Length;
+        while (end > 0 && char.IsDigit(candidate[end - 1]))
+            end--;
+
+        if (end == candidate.Length || end < 3)
+            return candidate;
+
+        var stem = candidate[..end];
+        var trailingLetters = 0;
+        for (var index = stem.Length - 1; index >= 0 && char.IsLetter(stem[index]); index--)
+            trailingLetters++;
+
+        // OCR7SR12CTRL => role CTRL, ordinal 12, IEDName OCR7SR.
+        // Do not strip product digits from names that do not have a stable letter stem.
+        return trailingLetters >= 2 && stem[..^trailingLetters].Any(char.IsDigit)
+            ? stem
+            : candidate;
+    }
