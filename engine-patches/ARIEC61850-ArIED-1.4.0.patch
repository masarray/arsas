+    private static int FindKnownRoleStart(string domain)
+    {
+        for (var index = 2; index < domain.Length; index++)
+        {
+            var tail = domain[index..];
+            foreach (var role in KnownLdRolePrefixes.OrderByDescending(x => x.Length))
+            {
+                if (!tail.StartsWith(role, StringComparison.OrdinalIgnoreCase))
+                    continue;
+
+                // A role may be followed by an ordinal or project suffix. Requiring a
+                // case/digit boundary avoids treating letters inside the IED name as LDInst.
+                var previous = domain[index - 1];
+                var boundaryBefore = char.IsDigit(previous) ||
+                                     previous is '_' or '-' or '.' ||
+                                     (char.IsLower(previous) && char.IsUpper(domain[index]));
