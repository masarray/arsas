<UserControl x:Class="ArIED61850Tester.Views.GooseSubscriberLiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ArIED61850Tester.Views"
             MinWidth="900" MinHeight="560">
    <UserControl.Resources>
        <views:GooseEngineeringValueConverter x:Key="GooseValueConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="9"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,0,8,0"/>
                        <TextBlock Text="GOOSE Subscriber" FontSize="14.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                        <Border Margin="8,0,0,0" Background="#EEF4FF" BorderBrush="#C9D9F1"
                                BorderThickness="1" CornerRadius="8" Padding="6,2">
                            <TextBlock Text="READ ONLY" FontSize="8.7" FontWeight="Bold" Foreground="#45648E"/>
                        </Border>
                    </StackPanel>

                    <ComboBox Grid.Column="2" ItemsSource="{Binding GooseAdapters}"
                              SelectedItem="{Binding SelectedGooseAdapter, Mode=TwoWay}"
                              Style="{StaticResource ModernComboBox}" Height="34" Padding="10,4"
                              IsHitTestVisible="{Binding CanRefreshGooseConfiguration}"
                              Focusable="{Binding CanRefreshGooseConfiguration}"
                              ToolTip="{Binding SelectedGooseAdapterDetail}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="4" Style="{StaticResource IedIconButton}"
                            Click="RefreshAdapters_Click" IsEnabled="{Binding CanRefreshGooseConfiguration}"
                            ToolTip="Refresh network adapters">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource LucideRefreshCw}" Style="{StaticResource LucideIcon}"/>
                        </Viewbox>
                    </Button>

                    <Button Grid.Column="6" Style="{StaticResource IedIconButton}"
                            Click="RefreshModels_Click" IsEnabled="{Binding CanRefreshGooseConfiguration}"
                            ToolTip="Refresh signal names from SCL and live discovery">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource LucideSlidersHorizontal}" Style="{StaticResource LucideIcon}"/>
                        </Viewbox>
                    </Button>

                    <Button Grid.Column="8" Style="{StaticResource CommandOpenButton}"
                            Click="StartCapture_Click" IsEnabled="{Binding CanStartGooseSubscriber}"
                            Padding="13,6" MinHeight="34">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                                <Path Data="{StaticResource LucidePlay}" Style="{StaticResource LucideIcon}" Stroke="White"/>
                            </Viewbox>
                            <TextBlock Text="Start" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="10" Style="{StaticResource SoftButton}"
                            Click="StopCapture_Click" IsEnabled="{Binding CanStopGooseSubscriber}"
                            Padding="11,6" MinHeight="34">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                                <Path Data="{StaticResource LucideSquare}" Style="{StaticResource LucideIcon}"
                                      Stroke="{StaticResource Warning}"/>
                            </Viewbox>
                            <TextBlock Text="Stop"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="12" Style="{StaticResource SoftButton}"
                            Click="ClearCapture_Click" Padding="11,6" MinHeight="34"
                            ToolTip="Clear publishers and events">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                                <Path Data="{StaticResource LucideX}" Style="{StaticResource LucideIcon}"
                                      Stroke="{StaticResource Danger}"/>
                            </Viewbox>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border CornerRadius="9" Padding="8,3" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F2F4F7"/>
                                <Setter Property="BorderBrush" Value="#D0D5DD"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGooseCapturing}" Value="True">
                                        <Setter Property="Background" Value="#E8F8EF"/>
                                        <Setter Property="BorderBrush" Value="#86D3A7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding GooseCaptureStateText}" FontSize="9.6" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#667085"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGooseCapturing}" Value="True">
                                            <Setter Property="Foreground" Value="#067647"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding GooseStatusText}" FontSize="10.5"
                               Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding GooseBindingText}"/>
                    <TextBlock Grid.Column="3" Text="{Binding GooseCounterText}" FontSize="10.5"
                               FontWeight="SemiBold" Foreground="#45648E" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238"/>
                <ColumnDefinition Width="9"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
                <ColumnDefinition Width="9"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="7"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource Accent}" Margin="0,0,7,0"/>
                            <TextBlock Text="Publishers" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource Ink}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#EEF4FF" BorderBrush="#C9D9F1"
                                BorderThickness="1" CornerRadius="9" Padding="7,2">
                            <TextBlock Text="{Binding GoosePublisherCountText}" FontSize="9.4"
                                       FontWeight="SemiBold" Foreground="#45648E"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <ListBox ItemsSource="{Binding GooseStreams}"
                                 SelectedItem="{Binding SelectedGooseStream, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Card" Background="#FBFDFF" BorderBrush="#D8E2F0"
                                                        BorderThickness="1" CornerRadius="11" Padding="8,7">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Card" Property="Background" Value="#F2F7FF"/>
                                                        <Setter TargetName="Card" Property="BorderBrush" Value="#AFC7E8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Card" Property="Background" Value="#E7F0FF"/>
                                                        <Setter TargetName="Card" Property="BorderBrush" Value="#6F9FF1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="49">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse x:Name="HealthDot" Width="7" Height="7" Fill="#16A34A"
                                                     Margin="0,0,7,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11.4"
                                                       FontWeight="SemiBold" Foreground="{StaticResource Ink}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="2" Background="#F2F4F7" BorderBrush="#D0D5DD"
                                                    BorderThickness="1" CornerRadius="7" Padding="5,1" Margin="5,0,0,0">
                                                <TextBlock Text="{Binding AppIdText}" FontSize="8.5" Foreground="#475467"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding DisplaySecondary}" FontSize="9.4"
                                                   Foreground="{StaticResource Muted}" Margin="14,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Grid Grid.Row="2" Margin="14,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding StateSequenceCompactText}" FontSize="9.1" Foreground="#45648E"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SequenceStatus}" FontSize="9.1"
                                                       Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasDiagnostics}" Value="True">
                                            <Setter TargetName="HealthDot" Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Visibility="{Binding GooseNoStreamsVisibility}" Background="#FAFCFF"
                                BorderBrush="#DCE6F3" BorderThickness="1" CornerRadius="11"
                                Padding="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="No publishers" FontSize="12.4" FontWeight="SemiBold"
                                           Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Choose an adapter and press Start." FontSize="10"
                                           Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="7"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Event timeline" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource Ink}"/>
                            <Border Margin="8,0,0,0" Background="#EEF4FF" BorderBrush="#C9D9F1"
                                    BorderThickness="1" CornerRadius="9" Padding="7,2">
                                <TextBlock Text="{Binding GooseEventCountText}" FontSize="9.4"
                                           FontWeight="SemiBold" Foreground="#45648E"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Changes &amp; warnings" FontSize="9.4"
                                   Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <DataGrid ItemsSource="{Binding GooseEvents}"
                                  SelectedItem="{Binding SelectedGooseEvent, Mode=TwoWay}"
                                  IsReadOnly="True" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" RowHeight="38"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding EventTone}" Value="Warning"/>
                                                <Condition Binding="{Binding IsRecent}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FFFAEB"/>
                                            <Setter Property="BorderBrush" Value="#FEC84B"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding EventTone}" Value="Change"/>
                                                <Condition Binding="{Binding IsRecent}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#EEF5FF"/>
                                            <Setter Property="BorderBrush" Value="#84ADFF"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                        </MultiDataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DDEAFF"/>
                                            <Setter Property="BorderBrush" Value="#4F86E5"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="88"/>
                                <DataGridTextColumn Header="Δt" Binding="{Binding DeltaText}" Width="72"/>
                                <DataGridTemplateColumn Header="Event" Width="102">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="Badge" Background="#EEF4FF" BorderBrush="#C9D9F1"
                                                    BorderThickness="1" CornerRadius="8" Padding="7,2"
                                                    HorizontalAlignment="Left">
                                                <TextBlock x:Name="Text" Text="{Binding EventText}" FontSize="9.3"
                                                           FontWeight="SemiBold" Foreground="#45648E"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding EventTone}" Value="Change">
                                                    <Setter TargetName="Badge" Property="Background" Value="#E8F1FF"/>
                                                    <Setter TargetName="Badge" Property="BorderBrush" Value="#84ADFF"/>
                                                    <Setter TargetName="Text" Property="Foreground" Value="#175CD3"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EventTone}" Value="Warning">
                                                    <Setter TargetName="Badge" Property="Background" Value="#FFFAEB"/>
                                                    <Setter TargetName="Badge" Property="BorderBrush" Value="#FEC84B"/>
                                                    <Setter TargetName="Text" Property="Foreground" Value="#B54708"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="155" MinWidth="120"/>
                                <DataGridTextColumn Header="st / sq" Binding="{Binding StateSequenceText}" Width="78"/>
                                <DataGridTextColumn Header="Changed values" Binding="{Binding Summary}" Width="*" MinWidth="150"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Visibility="{Binding GooseNoEventsVisibility}" Background="#FAFCFF"
                                BorderBrush="#DCE6F3" BorderThickness="1" CornerRadius="11"
                                Padding="15" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320">
                            <StackPanel>
                                <TextBlock Text="Waiting for a meaningful event" FontSize="12.4"
                                           FontWeight="SemiBold" Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                                <TextBlock Text="New publishers, state changes and warnings appear here."
                                           FontSize="10" Foreground="{StaticResource Muted}" TextAlignment="Center"
                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="7"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource Accent}" Margin="0,0,7,0"/>
                            <TextBlock Text="GOOSE Inspector" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource Ink}"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="9" Padding="7,2" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#ECFDF3"/>
                                    <Setter Property="BorderBrush" Value="#86EFAC"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedGooseStream.HasDiagnostics}" Value="True">
                                            <Setter Property="Background" Value="#FFFAEB"/>
                                            <Setter Property="BorderBrush" Value="#FEC84B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedGooseStream.HealthText}" FontSize="9.2" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedGooseStream}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedGooseStream.DisplayName}" FontSize="14.5"
                                           FontWeight="SemiBold" Foreground="{StaticResource Ink}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedGooseStream.DisplaySecondary}" FontSize="10.2"
                                           Foreground="{StaticResource Muted}" Margin="0,2,0,8"
                                           TextTrimming="CharacterEllipsis"/>

                                <Border Background="#F8FBFF" BorderBrush="#DCE6F3" BorderThickness="1"
                                        CornerRadius="11" Padding="9" Margin="0,0,0,7">
                                    <StackPanel>
                                        <TextBlock Text="Identity" FontSize="11.4" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Ink}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="IED" FontSize="9.6" Foreground="{StaticResource Muted}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedGooseStream.ModelIedDisplay}" FontSize="10.1"
                                                       FontWeight="SemiBold" Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="GOOSE ID" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGooseStream.GooseIdDisplay}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="2" Text="APPID" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGooseStream.AppIdText}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Text="DataSet" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGooseStream.DataSetShortName}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding SelectedGooseStream.DataSetReference}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F8FBFF" BorderBrush="#DCE6F3" BorderThickness="1"
                                        CornerRadius="11" Padding="9" Margin="0,0,0,7">
                                    <StackPanel>
                                        <TextBlock Text="Communication" FontSize="11.4" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Ink}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Source" FontSize="9.6" Foreground="{StaticResource Muted}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedGooseStream.SourceMac}" FontSize="9.9" Foreground="{StaticResource Ink}"/>
                                            <TextBlock Grid.Row="1" Text="Destination" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGooseStream.DestinationMac}" FontSize="9.9"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Text="VLAN" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGooseStream.VlanText}" FontSize="9.9"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Text="TAL" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGooseStream.TimeAllowedToLiveText}" FontSize="9.9"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F8FBFF" BorderBrush="#DCE6F3" BorderThickness="1"
                                        CornerRadius="11" Padding="9" Margin="0,0,0,7">
                                    <StackPanel>
                                        <TextBlock Text="Current state" FontSize="11.4" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Ink}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="st / sq" FontSize="9.6" Foreground="{StaticResource Muted}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedGooseStream.StateSequenceText}" FontSize="10.1"
                                                       FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                            <TextBlock Grid.Row="1" Text="Event" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGooseStream.SequenceStatus}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Text="confRev" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGooseStream.ConfigurationRevisionText}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Text="Model" FontSize="9.6" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGooseStream.ModelStateText}" FontSize="10.1"
                                                       Foreground="{StaticResource Ink}" Margin="0,4,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="#FFFAEB" BorderBrush="#FEC84B" BorderThickness="1"
                                        CornerRadius="11" Padding="9" Margin="0,0,0,7">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedGooseStream.HasDiagnostics}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="Needs attention" FontSize="11" FontWeight="SemiBold" Foreground="#B54708"/>
                                        <TextBlock Text="{Binding SelectedGooseStream.DiagnosticsSummary}" FontSize="9.6"
                                                   Foreground="#7A2E0E" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="DataSet values" FontSize="11.6" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                    <Border Grid.Column="1" Background="#EEF4FF" BorderBrush="#C9D9F1"
                                            BorderThickness="1" CornerRadius="8" Padding="6,2">
                                        <TextBlock Text="{Binding GooseSelectedLeafCountText}" FontSize="9" Foreground="#45648E"/>
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SelectedGooseStream.Leaves}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FBFDFF" BorderBrush="#DCE6F3" BorderThickness="1"
                                                    CornerRadius="9" Padding="7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="22"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Order}" FontSize="9.3" Foreground="#45648E"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="2,0,7,0">
                                                        <TextBlock Text="{Binding SignalName}" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding SignalReference}" FontSize="8.6"
                                                                   Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding SignalReference}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border x:Name="ValueBadge" Background="#F2F4F7" BorderBrush="#D0D5DD"
                                                                BorderThickness="1" CornerRadius="8" Padding="7,3">
                                                            <TextBlock Text="{Binding Value, Converter={StaticResource GooseValueConverter}}"
                                                                       FontSize="9.6" FontWeight="SemiBold" Foreground="#344054"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="120" ToolTip="{Binding Value}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding TypeText}" FontSize="8.3" Foreground="{StaticResource Muted}"
                                                                   HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter TargetName="ValueBadge" Property="Background" Value="#FFF1C7"/>
                                                    <Setter TargetName="ValueBadge" Property="BorderBrush" Value="#F59E0B"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Background="#FAFCFF" BorderBrush="#DCE6F3" BorderThickness="1"
                                CornerRadius="11" Padding="15" HorizontalAlignment="Center"
                                VerticalAlignment="Center" MaxWidth="260">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedGooseStream}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Select a publisher" FontSize="12.4" FontWeight="SemiBold"
                                           Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Identity, network state and DataSet values appear here."
                                           FontSize="10" Foreground="{StaticResource Muted}" TextAlignment="Center"
                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
