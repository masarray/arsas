<Window x:Class="ArIED61850Tester.SmvViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMV Viewer"
        Width="980" Height="640" MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundGradient}"
        FontFamily="Aptos, Segoe UI Variable Text, Segoe UI, Calibri"
        Icon="Assets/app-icon.ico">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding DeviceName}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink}"/>
                    <TextBlock Text="{Binding EndpointText}" Margin="0,3,0,0" FontSize="11.5"
                               Foreground="{StaticResource Muted}"/>
                </StackPanel>
                <Border Grid.Column="1" Padding="9,4" CornerRadius="11"
                        Background="#EAF2FF" BorderBrush="#BDD2F4" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="SMV / IEC 61850-9-2" FontSize="11" FontWeight="SemiBold"
                               Foreground="#245EA8"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Accent}" Margin="0,0,7,0"/>
                        <TextBlock Text="Configured and discovered streams" Style="{StaticResource SectionTitle}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding StreamCountText}" FontSize="11.5"
                               Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                </Grid>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Streams}" SelectedItem="{Binding SelectedStream, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          CanUserDeleteRows="False" CanUserResizeRows="False" CanUserReorderColumns="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderThickness="0" Background="Transparent"
                          RowHeaderWidth="0" SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="105"/>
                        <DataGridTextColumn Header="Control block" Binding="{Binding ControlReference}" Width="210"/>
                        <DataGridTextColumn Header="svID / smvID" Binding="{Binding StreamId}" Width="140"/>
                        <DataGridTextColumn Header="DataSet" Binding="{Binding DataSetReference}" Width="210"/>
                        <DataGridTextColumn Header="APPID" Binding="{Binding AppId}" Width="75"/>
                        <DataGridTextColumn Header="Destination MAC" Binding="{Binding DestinationMac}" Width="125"/>
                        <DataGridTextColumn Header="VLAN" Binding="{Binding Vlan}" Width="62"/>
                        <DataGridTextColumn Header="Rate" Binding="{Binding SampleRate}" Width="70"/>
                        <DataGridTextColumn Header="Mode" Binding="{Binding SampleMode}" Width="78"/>
                        <DataGridTextColumn Header="ASDU" Binding="{Binding NumberOfAsdu}" Width="62"/>
                        <DataGridTextColumn Header="Members" Binding="{Binding MemberCount}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="11.5" Foreground="{StaticResource Ink}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedStreamDetail}" Margin="0,3,0,0" FontSize="10.8"
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Close" Width="82" Margin="12,0,0,0"
                        Style="{StaticResource SoftButton}" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>